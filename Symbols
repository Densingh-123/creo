        public static void SetCustomOrientation()
        {
            IpfcAsyncConnection connection = null;

            try
            {
                MessageBox.Show("Connecting to active Creo session...");

             
                IpfcModel model = Session.CurrentModel;

                // 3. Ensure a model is active and check that it is a valid Part file
                if (model == null || (int)model.Type != (int)EpfcModelType.EpfcMDL_PART)
                {
                    MessageBox.Show("ERROR: Please open a valid Creo Part model first.");
                    return;
                }

                // 4. Instantiate a blank 3D Matrix block using CpfcMatrix3D
                IpfcMatrix3D matrix = new CpfcMatrix3D();

                // Row 0: Screen X-Axis Direction (Right)
                matrix.Set(0, 0, 1.0); matrix.Set(0, 1, 0.0); matrix.Set(0, 2, 0.0); matrix.Set(0, 3, 0.0);

                // Row 1: Screen Y-Axis Direction (Up)
                matrix.Set(1, 0, 0.0); matrix.Set(1, 1, 1.0); matrix.Set(1, 2, 0.0); matrix.Set(1, 3, 0.0);

                // Row 2: Screen Z-Axis Direction (Towards User)
                matrix.Set(2, 0, 0.0); matrix.Set(2, 1, 0.0); matrix.Set(2, 2, 1.0); matrix.Set(2, 3, 0.0);

                // Row 3: Position Translation Layout (No panning offset)
                matrix.Set(3, 0, 0.0); matrix.Set(3, 1, 0.0); matrix.Set(3, 2, 0.0); matrix.Set(3, 3, 1.0);

                // 5. Package matrix into a 3D Transform definition instance
                IpfcTransform3D transform = new CCpfcTransform3D().Create(matrix);

                // 6. FIX: Cast model to IpfcViewOwner interface to expose orientation methods
                IpfcViewOwner viewOwner = (IpfcViewOwner)model;

                // 7. FIX: Apply the transformation directly to the active model viewport screen state
                viewOwner.SetCurrentViewTransform(transform);

                // 8. FIX: Save the active screen layout look directly into a named view orientation slot
                string viewName = "MY_ORIENTATION";
                viewOwner.SaveView(viewName);

                // 9. Query the active window workspace viewport and flush canvas updates
                IpfcWindow currentWindow = Session.get_CurrentWindow();
                if (currentWindow != null)
                {
                    currentWindow.Repaint();
                }

                MessageBox.Show("SUCCESS: Custom Orientation '" + viewName + "' has been successfully registered!");
            }
            catch (Exception ex)
            {
                MessageBox.Show("EXECUTION ERROR: " + ex.Message);
            }
            finally
            {
                if (connection != null)
                {
                    connection.Disconnect(null);
                    MessageBox.Show("Disconnected cleanly from Creo.");
                }
            }

            MessageBox.Show("Press any key to exit...");
            Console.ReadKey();
        }



    }
