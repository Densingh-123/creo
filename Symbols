        public void GetSymbols()
        {
            try
            {
                IpfcModel model = Session.CurrentModel;

                if (model == null)
                {
                    MessageBox.Show("No active model found.");
                    return;
                }

                if (model.Type != (int)EpfcModelType.EpfcMDL_DRAWING)
                {
                    MessageBox.Show("Current model is not a drawing.");
                    return;
                }

                IpfcDrawing drawing = (IpfcDrawing)model;
                IpfcDetailItemOwner owner = (IpfcDetailItemOwner)drawing;

                StringBuilder sb = new StringBuilder();
                sb.AppendLine(" DRAWING SYMBOL COMPONENTS ");


                IpfcDetailItems items = owner.ListDetailItems(EpfcDetailType.EpfcDETAIL_SYM_INSTANCE, null);

                if (items != null && items.Count > 0)
                {
                    for (int i = 0; i < items.Count; i++)
                    {
                        IpfcDetailSymbolInstItem drwitem = (IpfcDetailSymbolInstItem)items[i];
                        string symbolName = " ";

                        try
                        {
                            IpfcDetailSymbolInstInstructions inst = drwitem.GetInstructions(false);

                            if (inst != null && inst.SymbolDef != null)
                            {

                                IpfcDetailSymbolDefInstructions defInsts = inst.SymbolDef.GetInstructions();
                                if (defInsts != null)
                                {
                                    symbolName = defInsts.Name;
                                }

                                sb.AppendLine($"\n[Symbol Instance {i + 1}] Name: {symbolName}");


                                IpfcDetailItems internalElements = inst.SymbolDef.ListDetailItems(EpfcDetailType.EpfcDETAIL_NOTE);

                                if (internalElements != null && internalElements.Count > 0)
                                {
                                    sb.AppendLine("  Internal Notes Found:");

                                    for (int e = 0; e < internalElements.Count; e++)
                                    {
                                        IpfcDetailItem componentItem = internalElements[e];


                                        if (componentItem.GetDetailType() == (int)EpfcDetailType.EpfcDETAIL_NOTE)
                                        {
                                            IpfcDetailNoteItem internalNote = (IpfcDetailNoteItem)componentItem;
                                            string notetext = "";

                                            try
                                            {
                                                IpfcDetailNoteInstructions noteinst = internalNote.GetInstructions(true);
                                                if (noteinst != null && noteinst.TextLines != null)
                                                {
                                                    for (int l = 0; l < noteinst.TextLines.Count; l++)
                                                    {
                                                        var parts = noteinst.TextLines[l].Texts;
                                                        for (int t = 0; t < parts.Count; t++)
                                                        {
                                                            notetext += parts[t].Text;
                                                        }
                                                    }
                                                }

                                                sb.AppendLine($" {notetext}");
                                            }
                                            catch
                                            {
                                                sb.AppendLine(" -> [Unreachable Text]");
                                            }
                                        }
                                    }
                                }
                                else
                                {
                                    sb.AppendLine("(No internal note elements discovered in this definition)");
                                }
                            }
                        }
                        catch (Exception ex)
                        {
                            symbolName = "Error Reading (" + ex.Message + ")";
                            sb.AppendLine($"Symbol Instance {i + 1} {symbolName}");
                        }
                    }
                }
                else
                {
                    sb.AppendLine("No symbol instances discovered on drawing sheet layers.");
                }

                MessageBox.Show(sb.ToString(), "Creo Symbol Manifest Result");
            }
            catch (Exception ex)
            {
                MessageBox.Show("Global Error: " + ex.Message);
            }
        }
        public static void ModifyLShapePipe()
        {
            try
            {
                IpfcModel model = Session.CurrentModel;

                if (model == null)
                {
                    MessageBox.Show("No active model found.");
                    return;
                }

                if (model.Type != (int)EpfcModelType.EpfcMDL_PART)
                {
                    MessageBox.Show("Active model is not a Part.");
                    return;
                }

                IpfcPart part = (IpfcPart)model;

                IpfcModelItemOwner owner = (IpfcModelItemOwner)part;

                IpfcModelItems surfaces =
                    owner.ListItems((int)EpfcModelItemType.EpfcITEM_SURFACE);

                if (surfaces == null || surfaces.Count == 0)
                {
                    MessageBox.Show("No surfaces found.");
                    return;
                }

                int pointsCreated = 0;

                for (int i = 0; i < surfaces.Count; i++)
                {
                    IpfcSurface surface = (IpfcSurface)surfaces[i];

                    if (surface.GetSurfaceType() ==
                        (int)EpfcSurfaceType.EpfcSURFACE_PLANE)
                    {
                        pointsCreated++;
                    }
                }

                ((IpfcSolid)part).Regenerate(null);
                MessageBox.Show(
                    $"Found {pointsCreated} planar end surfaces.");
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }
        }
        public static void CalculateLongestPipeDistance()
        {
            try
            {
                IpfcModel model = Session.CurrentModel;
                if (model == null)
                {
                    MessageBox.Show("No active model found.");
                    return;
                }

                if (model.Type != (int)EpfcModelType.EpfcMDL_PART)
                {
                    MessageBox.Show("Active model is not a 3D Part (.prt).");
                    return;
                }

                IpfcPart part = (IpfcPart)model;
                IpfcModelItemOwner owner = (IpfcModelItemOwner)part;

                IpfcModelItems pointsCollection = owner.ListItems((int)EpfcModelItemType.EpfcITEM_POINT);

                if (pointsCollection == null || pointsCollection.Count < 2)
                {
                    MessageBox.Show("At least two points are required in the model.");
                    return;
                }

                IpfcSelection endPoint1 = null;
                IpfcSelection endPoint2 = null;

                for (int i = 0; i < pointsCollection.Count; i++)
                {

                    IpfcModelItem pointItem = (IpfcModelItem)pointsCollection[i];

                    IpfcSelection currentSel = new CMpfcSelect().CreateModelItemSelection(pointItem, null);

                    if (endPoint1 == null)
                    {
                        endPoint1 = currentSel;
                    }
                    else if (endPoint2 == null)
                    {
                        endPoint2 = currentSel;
                        break;
                    }
                }

                if (endPoint1 == null || endPoint2 == null)
                {
                    MessageBox.Show("Could not successfully select two points.");
                    return;
                }

                IpfcSelectionPair selectionPair = new CCpfcSelectionPair().Create(endPoint1, endPoint2);

                IpfcSelectionEvaluator evaluator = new CMpfcInterference().CreateSelectionEvaluator(selectionPair);
                IpfcCriticalDistanceData distanceData = evaluator.ComputeNearestCriticalDistance();

                if (distanceData != null)
                {
                    double totalPipeLength = distanceData.Distance;
                    MessageBox.Show($"Pipe Feature Analysis Complete!\n\n" +
                                    $"Distance Between Points: {totalPipeLength:F4} units");
                }
                else
                {
                    MessageBox.Show("Distance calculation returned null data.");
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Creo API Error: " + ex.Message);
            }
        }

        public static void GetSymbolsCustomizationData()
        {
            try
            {
                if (Session == null)
                {
                    MessageBox.Show("Creo session is not available.");
                    return;
                }

                IpfcModel model = Session.CurrentModel;

                if (model == null)
                {
                    MessageBox.Show("No active model.");
                    return;
                }

                if (model.Type != (int)EpfcModelType.EpfcMDL_DRAWING)
                {
                    MessageBox.Show("Current model is not a drawing.");
                    return;
                }

                IpfcDrawing drawing = (IpfcDrawing)model;
                IpfcModelItemOwner owner = (IpfcModelItemOwner)drawing;

                StringBuilder result = new StringBuilder();

                result.AppendLine(" SYMBOL DEFINITIONS ");
                result.AppendLine();

                IpfcModelItems defItems =
                    owner.ListItems((int)EpfcModelItemType.EpfcITEM_DTL_SYM_DEFINITION);

                if (defItems == null || defItems.Count == 0)
                {
                    MessageBox.Show("No symbol definitions found.");
                    return;
                }

                for (int i = 0; i < defItems.Count; i++)
                {
                    IpfcDetailSymbolDefItem symDef =
                        (IpfcDetailSymbolDefItem)defItems[i];

                    IpfcDetailSymbolDefInstructions defInst =
                        symDef.GetInstructions();


                    result.AppendLine("Symbol Definition : " + defInst.Name);


                    try
                    {
                        IpfcDetailSymbolGroups groups = symDef.ListSubgroups();

                        if (groups != null && groups.Count > 0)
                        {
                            for (int j = 0; j < groups.Count; j++)
                            {
                                PrintGroup(groups[j], result, 1);
                            }
                        }
                        else
                        {
                            result.AppendLine("No groups found.");
                        }
                    }
                    catch
                    {
                        result.AppendLine("No groups defined.");
                    }

                    result.AppendLine();
                }

                MessageBox.Show(result.ToString());
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }
        }

        private static void PrintGroup(
            IpfcDetailSymbolGroup group,
            StringBuilder result,
            int level)
        {
            if (group == null)
                return;

            IpfcDetailSymbolGroupInstructions inst =
                group.GetInstructions();

            result.AppendLine(
                new string(' ', level * 4) +
                "Group : " + inst.Name);

            try
            {
                IpfcDetailSymbolGroups children = group.ListChildren();

                if (children != null && children.Count > 0)
                {
                    for (int i = 0; i < children.Count; i++)
                    {
                        PrintGroup(children[i], result, level + 1);
                    }
                }
            }
            catch
            {
                // No child groups
            }
        }
        public static void GetAllSymbolsCustomizationData(IpfcBaseSession Session)
        {
            try
            {

                if (Session == null)
                {
                    MessageBox.Show("Creo session is not available.");
                    return;
                }


                IpfcModel model = Session.CurrentModel;


                if (model == null)
                {
                    MessageBox.Show("No active model.");
                    return;
                }



                if (model.Type != (int)EpfcModelType.EpfcMDL_DRAWING)
                {
                    MessageBox.Show("Current model is not a drawing.");
                    return;
                }



                IpfcDrawing drawing = (IpfcDrawing)model;


                StringBuilder result = new StringBuilder();


                result.AppendLine("===== SYMBOL CUSTOMIZATION DATA =====");
                result.AppendLine();



                int symbolCount = 0;

                IpfcModelItemOwner owner = (IpfcModelItemOwner)drawing;
                IpfcModelItems items = owner.ListItems(
                    (int)EpfcModelItemType.EpfcITEM_DTL_SYM_DEFINITION
                );



                if (items == null || items.Count == 0)
                {
                    MessageBox.Show(
                        "No detail items found in drawing."
                    );

                    return;
                }



                for (int i = 0; i < items.Count; i++)
                {

                    IpfcDetailItem detailItem = (IpfcDetailItem)items[i];


                    if (detailItem == null)
                        continue;



                    if (detailItem.GetDetailType()
                        != (int)EpfcDetailType.EpfcDETAIL_SYM_INSTANCE)
                    {
                        continue;
                    }



                    symbolCount++;


                    IpfcDetailSymbolInstItem symbol =
                        (IpfcDetailSymbolInstItem)detailItem;



                    result.AppendLine(
                        "----------- Symbol "
                        + symbolCount
                        + " -----------"
                    );

                    try
                    {

                        IpfcDetailSymbolInstInstructions instructions =
                            symbol.GetInstructions(false);



                        if (instructions == null)
                        {
                            result.AppendLine(
                                "No instructions available."
                            );

                            continue;
                        }



                        if (instructions.SymbolDef != null)
                        {
                            result.AppendLine(
                                "Symbol definition exists."
                            );
                        }
                        else
                        {
                            result.AppendLine(
                                "Symbol definition not available."
                            );
                        }
                        try
                        {

                            IpfcDetailVariantTexts texts =
                                instructions.get_TextValues();



                            if (texts != null &&
                                texts.Count > 0)
                            {

                                result.AppendLine(
                                    "Variable Text Values:"
                                );


                                for (int j = 0;
                                     j < texts.Count;
                                     j++)
                                {

                                    IpfcDetailVariantText text =
                                        texts[j];


                                    result.AppendLine(
                                        "  "
                                        + text.Value
                                    );

                                }

                            }
                            else
                            {
                                result.AppendLine(
                                    "No variable text values."
                                );
                            }


                        }
                        catch
                        {
                            result.AppendLine(
                                "Unable to read text customization."
                            );
                        }


                    }
                    catch (Exception ex)
                    {

                        result.AppendLine(
                            "Symbol read error : "
                            + ex.Message
                        );

                    }



                    result.AppendLine();

                }

                if (symbolCount == 0)
                {
                    MessageBox.Show(
                        "No symbol instances found."
                    );
                }
                else
                {

                    MessageBox.Show(
                        result.ToString(),
                        "Total Symbols : " + symbolCount
                    );

                }



            }
            catch (Exception ex)
            {

                MessageBox.Show(
                    ex.Message,
                    "Creo API Error"
                );

            }

        }
        public void GetSymbolGroups()
        {
            string _groups = "";
            int num = 0;
            StringBuilder sb = new StringBuilder();
            IpfcModel model = Session.CurrentModel;
            IpfcDrawing draw = (IpfcDrawing)model;
            IpfcModelItemOwner owner = (IpfcModelItemOwner)draw;
            IpfcModelItems modelitems = owner.ListItems(EpfcModelItemType.EpfcITEM_DTL_SYM_INSTANCE);
            int count = modelitems.Count;
            for (int i = 0; i < count; i++)
            {
                IpfcDetailSymbolInstItem institem = (IpfcDetailSymbolInstItem)modelitems[i];
                string name = institem.GetInstructions(false).SymbolDef.GetInstructions().Name;
                sb.Append(name);
                if (name == "SC_FLAGS_NOTES")
                {
                    IpfcDetailSymbolGroups val = institem.ListGroups((int)EpfcSymbolGroupFilter.EpfcDTLSYMINST_ACTIVE_GROUPS);
                    num = val.Count;
                    sb.Append(num);
                    for (int j = 0; j < num; j++)
                    {
                        _groups = val[j].GetInstructions().Name;
                        sb.Append(_groups);
                    }
                }

            }
            MessageBox.Show(sb.ToString());
        }
