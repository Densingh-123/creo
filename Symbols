        public void GetSymbols()
        {
            try
            {
                IpfcModel model = Session.CurrentModel;

                if (model == null)
                {
                    MessageBox.Show("No active model found.");
                    return;
                }

                if (model.Type != (int)EpfcModelType.EpfcMDL_DRAWING)
                {
                    MessageBox.Show("Current model is not a drawing.");
                    return;
                }

                IpfcDrawing drawing = (IpfcDrawing)model;
                IpfcDetailItemOwner owner = (IpfcDetailItemOwner)drawing;

                StringBuilder sb = new StringBuilder();
                sb.AppendLine(" DRAWING SYMBOL COMPONENTS ");


                IpfcDetailItems items = owner.ListDetailItems(EpfcDetailType.EpfcDETAIL_SYM_INSTANCE, null);

                if (items != null && items.Count > 0)
                {
                    for (int i = 0; i < items.Count; i++)
                    {
                        IpfcDetailSymbolInstItem drwitem = (IpfcDetailSymbolInstItem)items[i];
                        string symbolName = " ";

                        try
                        {
                            IpfcDetailSymbolInstInstructions inst = drwitem.GetInstructions(false);

                            if (inst != null && inst.SymbolDef != null)
                            {

                                IpfcDetailSymbolDefInstructions defInsts = inst.SymbolDef.GetInstructions();
                                if (defInsts != null)
                                {
                                    symbolName = defInsts.Name;
                                }

                                sb.AppendLine($"\n[Symbol Instance {i + 1}] Name: {symbolName}");


                                IpfcDetailItems internalElements = inst.SymbolDef.ListDetailItems(EpfcDetailType.EpfcDETAIL_NOTE);

                                if (internalElements != null && internalElements.Count > 0)
                                {
                                    sb.AppendLine("  Internal Notes Found:");

                                    for (int e = 0; e < internalElements.Count; e++)
                                    {
                                        IpfcDetailItem componentItem = internalElements[e];


                                        if (componentItem.GetDetailType() == (int)EpfcDetailType.EpfcDETAIL_NOTE)
                                        {
                                            IpfcDetailNoteItem internalNote = (IpfcDetailNoteItem)componentItem;
                                            string notetext = "";

                                            try
                                            {
                                                IpfcDetailNoteInstructions noteinst = internalNote.GetInstructions(true);
                                                if (noteinst != null && noteinst.TextLines != null)
                                                {
                                                    for (int l = 0; l < noteinst.TextLines.Count; l++)
                                                    {
                                                        var parts = noteinst.TextLines[l].Texts;
                                                        for (int t = 0; t < parts.Count; t++)
                                                        {
                                                            notetext += parts[t].Text;
                                                        }
                                                    }
                                                }

                                                sb.AppendLine($" {notetext}");
                                            }
                                            catch
                                            {
                                                sb.AppendLine(" -> [Unreachable Text]");
                                            }
                                        }
                                    }
                                }
                                else
                                {
                                    sb.AppendLine("(No internal note elements discovered in this definition)");
                                }
                            }
                        }
                        catch (Exception ex)
                        {
                            symbolName = "Error Reading (" + ex.Message + ")";
                            sb.AppendLine($"Symbol Instance {i + 1} {symbolName}");
                        }
                    }
                }
                else
                {
                    sb.AppendLine("No symbol instances discovered on drawing sheet layers.");
                }

                MessageBox.Show(sb.ToString(), "Creo Symbol Manifest Result");
            }
            catch (Exception ex)
            {
                MessageBox.Show("Global Error: " + ex.Message);
            }
        }
        public static void ModifyLShapePipe()
        {
            try
            {
                IpfcModel model = Session.CurrentModel;

                if (model == null)
                {
                    MessageBox.Show("No active model found.");
                    return;
                }

                if (model.Type != (int)EpfcModelType.EpfcMDL_PART)
                {
                    MessageBox.Show("Active model is not a Part.");
                    return;
                }

                IpfcPart part = (IpfcPart)model;

                IpfcModelItemOwner owner = (IpfcModelItemOwner)part;

                IpfcModelItems surfaces =
                    owner.ListItems((int)EpfcModelItemType.EpfcITEM_SURFACE);

                if (surfaces == null || surfaces.Count == 0)
                {
                    MessageBox.Show("No surfaces found.");
                    return;
                }

                int pointsCreated = 0;

                for (int i = 0; i < surfaces.Count; i++)
                {
                    IpfcSurface surface = (IpfcSurface)surfaces[i];

                    if (surface.GetSurfaceType() ==
                        (int)EpfcSurfaceType.EpfcSURFACE_PLANE)
                    {
                        pointsCreated++;
                    }
                }

                ((IpfcSolid)part).Regenerate(null);
                MessageBox.Show(
                    $"Found {pointsCreated} planar end surfaces.");
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }
        }
   
        public static void GetSymbolsCustomizationData()
        {
            try
            {
