        private void Kill_Process(
           string processName)
        {
            try
            {
                Process[] processes =
                    Process.GetProcessesByName(
                        processName);

                foreach (Process process in processes)
                {
                    process.Kill();
                }
            }
            catch
            {
            }
        }
        public void FindSymbol()
        {
            try
            {

                IpfcModel model = Session.CurrentModel;

                if (model == null)
                {
                    MessageBox.Show("No active model found.");
                    return;
                }


                if (model.Type != (int)EpfcModelType.EpfcMDL_DRAWING)
                {
                    MessageBox.Show("Current model is not a drawing.");
                    return;
                }

                IpfcDrawing drawing = (IpfcDrawing)model;
                IpfcDetailItemOwner owner = (IpfcDetailItemOwner)drawing;

                StringBuilder output = new StringBuilder();
                int symbolCount = 0;
                int noteCount = 0;

                IpfcDetailItems symbols = owner.ListDetailItems(
                    EpfcDetailType.EpfcDETAIL_SYM_INSTANCE,
                    null
                );

                if (symbols != null && symbols.Count > 0)
                {
                    for (int i = 0; i < symbols.Count; i++)
                    {
                        symbolCount++;
                        IpfcDetailSymbolInstItem symbol = (IpfcDetailSymbolInstItem)symbols[i];

                        output.AppendLine("SYMBOL " + symbolCount);
                        try
                        {
                            IpfcDetailSymbolInstInstructions instructions = symbol.GetInstructions(false);
                            if (instructions != null)
                            {
                                output.AppendLine("Symbol instance found");
                            }
                        }
                        catch
                        {
                            output.AppendLine("Unable to read symbol data");
                        }
                        output.AppendLine("-------------------------");
                    }
                }

                IpfcDetailItems notes = owner.ListDetailItems(
                    EpfcDetailType.EpfcDETAIL_NOTE,
                    null
                );

                if (notes != null && notes.Count > 0)
                {
                    for (int i = 0; i < notes.Count; i++)
                    {
                        noteCount++;
                        IpfcDetailNoteItem note = (IpfcDetailNoteItem)notes[i];

                        output.AppendLine("NOTE " + noteCount);
                        try
                        {
                            IpfcDetailNoteInstructions noteInstruction = note.GetInstructions(true);
                            if (noteInstruction != null)
                            {
                                output.AppendLine("Note found");
                            }
                        }
                        catch
                        {
                            output.AppendLine("Unable to read note text");
                        }
                        output.AppendLine("-------------------------");
                    }
                }


                if (symbolCount == 0 && noteCount == 0)
                {
                    MessageBox.Show("No symbols or notes found.");
                    return;
                }


                StringBuilder final = new StringBuilder();
                final.AppendLine("DRAWING DETAIL INFORMATION");
                final.AppendLine("Total Symbols : " + symbolCount);
                final.AppendLine("Total Notes   : " + noteCount);
                final.AppendLine("");
                final.Append(output.ToString());

                MessageBox.Show(final.ToString(), "Creo Drawing Details");
            }
            catch (COMException ex)
            {
                MessageBox.Show("Creo Toolkit Error:\n\n" + ex.Message + "\n\nHRESULT : " + ex.ErrorCode);
            }
            catch (Exception ex)
            {
                MessageBox.Show("Error:\n" + ex.Message);
            }
        }

