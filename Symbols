                result.AppendLine(" SYMBOL DEFINITIONS ");
                result.AppendLine();

                IpfcModelItems defItems =
                    owner.ListItems((int)EpfcModelItemType.EpfcITEM_DTL_SYM_DEFINITION);

                if (defItems == null || defItems.Count == 0)
                {
                    MessageBox.Show("No symbol definitions found.");
                    return;
                }

                for (int i = 0; i < defItems.Count; i++)
                {
                    IpfcDetailSymbolDefItem symDef =
                        (IpfcDetailSymbolDefItem)defItems[i];

                    IpfcDetailSymbolDefInstructions defInst =
                        symDef.GetInstructions();


                    result.AppendLine("Symbol Definition : " + defInst.Name);


                    try
                    {
                        IpfcDetailSymbolGroups groups = symDef.ListSubgroups();

                        if (groups != null && groups.Count > 0)
                        {
                            for (int j = 0; j < groups.Count; j++)
                            {
                                PrintGroup(groups[j], result, 1);
                            }
                        }
                        else
                        {
                            result.AppendLine("No groups found.");
                        }
                    }
                    catch
                    {
                        result.AppendLine("No groups defined.");
                    }

                    result.AppendLine();
                }

                MessageBox.Show(result.ToString());
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }
        }

        private static void PrintGroup(
            IpfcDetailSymbolGroup group,
            StringBuilder result,
            int level)
        {
            if (group == null)
                return;

            IpfcDetailSymbolGroupInstructions inst =
                group.GetInstructions();

            result.AppendLine(
                new string(' ', level * 4) +
                "Group : " + inst.Name);

            try
            {
                IpfcDetailSymbolGroups children = group.ListChildren();

                if (children != null && children.Count > 0)
                {
                    for (int i = 0; i < children.Count; i++)
                    {
                        PrintGroup(children[i], result, level + 1);
                    }
                }
            }
            catch
            {
                // No child groups
            }
        }
        public static void GetAllSymbolsCustomizationData(IpfcBaseSession Session)
        {
            try
            {

                if (Session == null)
                {
                    MessageBox.Show("Creo session is not available.");
                    return;
                }


                IpfcModel model = Session.CurrentModel;


                if (model == null)
                {
                    MessageBox.Show("No active model.");
                    return;
                }



                if (model.Type != (int)EpfcModelType.EpfcMDL_DRAWING)
                {
                    MessageBox.Show("Current model is not a drawing.");
                    return;
                }



                IpfcDrawing drawing = (IpfcDrawing)model;


                StringBuilder result = new StringBuilder();


                result.AppendLine("===== SYMBOL CUSTOMIZATION DATA =====");
                result.AppendLine();



                int symbolCount = 0;

                IpfcModelItemOwner owner = (IpfcModelItemOwner)drawing;
                IpfcModelItems items = owner.ListItems(
                    (int)EpfcModelItemType.EpfcITEM_DTL_SYM_DEFINITION
                );



                if (items == null || items.Count == 0)
                {
                    MessageBox.Show(
                        "No detail items found in drawing."
                    );

                    return;
                }



                for (int i = 0; i < items.Count; i++)
                {

                    IpfcDetailItem detailItem = (IpfcDetailItem)items[i];


                    if (detailItem == null)
                        continue;



                    if (detailItem.GetDetailType()
                        != (int)EpfcDetailType.EpfcDETAIL_SYM_INSTANCE)
                    {
                        continue;
                    }



                    symbolCount++;


                    IpfcDetailSymbolInstItem symbol =
                        (IpfcDetailSymbolInstItem)detailItem;



                    result.AppendLine(
                        "----------- Symbol "
                        + symbolCount
                        + " -----------"
                    );

                    try
                    {

                        IpfcDetailSymbolInstInstructions instructions =
                            symbol.GetInstructions(false);



                        if (instructions == null)
                        {
                            result.AppendLine(
                                "No instructions available."
                            );

                            continue;
                        }



                        if (instructions.SymbolDef != null)
                        {
                            result.AppendLine(
                                "Symbol definition exists."
                            );
                        }
                        else
                        {
                            result.AppendLine(
                                "Symbol definition not available."
                            );
                        }
                        try
                        {

                            IpfcDetailVariantTexts texts =
                                instructions.get_TextValues();



                            if (texts != null &&
                                texts.Count > 0)
                            {

                                result.AppendLine(
                                    "Variable Text Values:"
                                );


                                for (int j = 0;
                                     j < texts.Count;
                                     j++)
                                {

                                    IpfcDetailVariantText text =
                                        texts[j];


                                    result.AppendLine(
                                        "  "
                                        + text.Value
                                    );

                                }

                            }
                            else
                            {
                                result.AppendLine(
                                    "No variable text values."
                                );
                            }


                        }
                        catch
                        {
                            result.AppendLine(
                                "Unable to read text customization."
                            );
                        }


                    }
                    catch (Exception ex)
                    {

                        result.AppendLine(
                            "Symbol read error : "
                            + ex.Message
                        );

                    }



                    result.AppendLine();

                }

                if (symbolCount == 0)
                {
                    MessageBox.Show(
                        "No symbol instances found."
                    );
                }
                else
                {

                    MessageBox.Show(
                        result.ToString(),
                        "Total Symbols : " + symbolCount
                    );

                }



            }
            catch (Exception ex)
            {

                MessageBox.Show(
                    ex.Message,
                    "Creo API Error"
                );

            }

        }
        public void GetSymbolGroups()
        {
            string _groups = "";
            int num = 0;
            StringBuilder sb = new StringBuilder();
            IpfcModel model = Session.CurrentModel;
            IpfcDrawing draw = (IpfcDrawing)model;
            IpfcModelItemOwner owner = (IpfcModelItemOwner)draw;
            IpfcModelItems modelitems = owner.ListItems(EpfcModelItemType.EpfcITEM_DTL_SYM_INSTANCE);
            int count = modelitems.Count;
            for (int i = 0; i < count; i++)
            {
                IpfcDetailSymbolInstItem institem = (IpfcDetailSymbolInstItem)modelitems[i];
                string name = institem.GetInstructions(false).SymbolDef.GetInstructions().Name;
                sb.Append(name);
                if (name == "SC_FLAGS_NOTES")
                {
                    IpfcDetailSymbolGroups val = institem.ListGroups((int)EpfcSymbolGroupFilter.EpfcDTLSYMINST_ACTIVE_GROUPS);
                    num = val.Count;
                    sb.Append(num);
                    for (int j = 0; j < num; j++)
                    {
                        _groups = val[j].GetInstructions().Name;
                        sb.Append(_groups);
                    }
                }

            }
            MessageBox.Show(sb.ToString());
        }
