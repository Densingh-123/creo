        public static IpfcView2D EnsureGeneralView(
            IpfcDrawing drawing,
            IpfcModel solid,
            string viewName,
            double x,
            double y)
        {
            try
            {
                if (drawing == null || solid == null) return null;

                IpfcModel2D drw2d = (IpfcModel2D)drawing;

                try
                {
                    IpfcView2Ds views = drw2d.List2DViews();
                    if (views != null)
                    {
                        for (int i = 0; i < views.Count; i++)
                        {
                            IpfcView2D v = views[i];
                            if (v != null && string.Equals(v.Name, viewName, StringComparison.OrdinalIgnoreCase))
                            {
                                Console.WriteLine("View exists: " + viewName);
                                return v;
                            }
                        }
                    }
                }
                catch { }

                IpfcTransform3D transform = BuildViewTransform(solid, viewName);
                if (transform == null)
                {
                    Console.WriteLine("No transform for view " + viewName + ", using identity.");
                    transform = CreateIdentityTransform();
                }

                CpfcPoint3D sheetPt = ToSheetPoint(drawing, MakePoint(x, y, 0));
                if (sheetPt == null)
                    sheetPt = MakePoint(x, y, 0);

                IpfcGeneralViewCreateInstructions gvi =
                    new CCpfcGeneralViewCreateInstructions().Create(solid, 1, sheetPt, transform);

                IpfcView2D newView = drw2d.CreateView((IpfcView2DCreateInstructions)gvi);
                try { if (newView != null) newView.Name = viewName; } catch { }
                Console.WriteLine("Created view " + viewName + " @ (" + x + "," + y + ")");
                return newView;
            }
            catch (Exception ex)
            {
                Console.WriteLine("EnsureGeneralView(" + viewName + ") failed: " + ex.Message);
                return null;
            }
        }

        // FIX: fully null-safe (was NullReferenceException here)
        private static IpfcTransform3D BuildViewTransform(IpfcModel solid, string viewName)
        {
            try
            {
                if (solid == null)
                    return CreateIdentityTransform();

                List<string> candidates = new List<string>();
                if (string.Equals(viewName, "ISO", StringComparison.OrdinalIgnoreCase))
                {
                    candidates.Add("ISO");
                    candidates.Add("ISOMETRIC");
                    candidates.Add("STD_ISO");
                    candidates.Add("TRIMETRIC");
                    candidates.Add("DEFAULT");
                }
                else if (!string.IsNullOrWhiteSpace(viewName))
                {
                    candidates.Add(viewName);
                }

                IpfcViewOwner owner = solid as IpfcViewOwner;
                if (owner != null)
                {
                    foreach (string cand in candidates)
                    {
                        try
                        {
                            IpfcView sourceView = owner.GetView(cand);
                            if (sourceView == null) continue;

                            IpfcTransform3D srcTr = null;
                            try { srcTr = sourceView.Transform; } catch { srcTr = null; }
                            if (srcTr == null) continue;

                            IpfcMatrix3D srcMatrix = null;
                            try { srcMatrix = srcTr.Matrix; } catch { srcMatrix = null; }
                            if (srcMatrix == null) continue;

                            CpfcMatrix3D matrix = srcMatrix as CpfcMatrix3D;
                            if (matrix == null)
                            {
                                // copy values if possible
                                matrix = new CpfcMatrix3D();
                                try
                                {
                                    for (int r = 0; r < 4; r++)
                                        for (int c = 0; c < 3; c++)
                                            matrix.Set(r, c, srcMatrix[r, c]);
                                }
                                catch
                                {
                                    IdentityMatrix(matrix);
                                }
                            }

                            NormalizeMatrix(matrix);
                            IpfcTransform3D tr = new CCpfcTransform3D().Create(matrix);
                            if (tr != null)
                                return tr;
                        }
                        catch
                        {
                            // try next candidate
                        }
                    }
                }

                // Fallback matrices
                CpfcMatrix3D m = new CpfcMatrix3D();
                if (m == null)
                    return CreateIdentityTransform();

                if (string.Equals(viewName, "ISO", StringComparison.OrdinalIgnoreCase))
                    IsoMatrix(m);
                else
                    IdentityMatrix(m);

                try
                {
                    IpfcTransform3D fallback = new CCpfcTransform3D().Create(m);
                    return fallback ?? CreateIdentityTransform();
                }
                catch
                {
                    return CreateIdentityTransform();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("BuildViewTransform warning: " + ex.Message);
                return CreateIdentityTransform();
            }
        }

        private static IpfcTransform3D CreateIdentityTransform()
        {
            try
            {
                CpfcMatrix3D m = new CpfcMatrix3D();
                IdentityMatrix(m);
                return new CCpfcTransform3D().Create(m);
            }
            catch
            {
                try { return new CCpfcTransform3D().Create(null); }
                catch { return null; }
            }
        }

        private static void TryProjection(IpfcDrawing drawing, IpfcView2D parent, string name, double dx, double dy)
        {
            try
            {
                if (drawing == null || parent == null) return;

                IpfcModel2D drw2d = (IpfcModel2D)drawing;

                try
