        private static void TryExplodeAssembly(IpfcBaseSession session, IpfcModel asmModel)
        {
            try
            {
                Console.WriteLine("Exploding assembly (best effort)...");
                try { asmModel.Display(); } catch { }
                ActivateModelWindow(session, asmModel);
                Thread.Sleep(300);

                string[] macros = new string[]
                {
                    "~ Command `ProCmdViewExpldStatToggle`;",
                    "~ Command `ProCmdEnvExplodedView` 1;",
                    "~ Command `ProCmdViewExplode`;"
                };

                foreach (string m in macros)
                {
                    try { session.RunMacro(m); Thread.Sleep(350); } catch { }
                }

                RefreshWindow(session);
            }
            catch (Exception ex)
            {
                Console.WriteLine("Explode skipped: " + ex.Message);
            }
        }

        private static List<IpfcModel> ListAssemblyPartModels(IpfcBaseSession session, IpfcModel asmModel)
        {
            List<IpfcModel> result = new List<IpfcModel>();
            HashSet<string> seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            try
            {
                IpfcAssembly asm = asmModel as IpfcAssembly;
                if (asm == null)
                    asm = session.CurrentModel as IpfcAssembly;

                if (asm != null)
                {
                    try
                    {
                        IpfcSolid solid = asm as IpfcSolid;
                        if (solid != null)
                        {
                            object feats = null;
                            try
                            {
                                feats = solid.ListFeaturesByType(true, EpfcFeatureType.EpfcFEATTYPE_COMPONENT);
                            }
                            catch
                            {
                                try
                                {
                                    MethodInfo mi = solid.GetType().GetMethod("ListFeaturesByType");
                                    if (mi != null)
                                        feats = mi.Invoke(solid, new object[] { true, EpfcFeatureType.EpfcFEATTYPE_COMPONENT });
                                }
                                catch { }
                            }

                            if (feats != null)
                            {
                                dynamic list = feats;
                                int count = 0;
                                try { count = (int)list.Count; } catch { }

                                for (int i = 0; i < count; i++)
                                {
                                    try
                                    {
                                        dynamic feat = list[i];
                                        IpfcModel m = null;

                                        try { m = feat.Model as IpfcModel; } catch { }
                                        if (m == null)
                                        {
                                            try { m = feat.get_Model() as IpfcModel; } catch { }
                                        }
                                        if (m == null)
                                        {
                                            try
                                            {
                                                MethodInfo gm = ((object)feat).GetType().GetMethod("GetModel", Type.EmptyTypes);
                                                if (gm != null) m = gm.Invoke(feat, null) as IpfcModel;
                                            }
                                            catch { }
                                        }

                                        if (m == null) continue;
                                        if (m.Type != MDL_PART) continue; // only parts get separate drawings

                                        string key = GetModelName(m);
                                        if (string.IsNullOrWhiteSpace(key)) continue;
                                        if (seen.Add(key))
                                            result.Add(m);
                                    }
                                    catch { }
                                }
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine("Component list warning: " + ex.Message);
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("ListAssemblyPartModels failed: " + ex.Message);
            }

            // Fallback: session models
            if (result.Count == 0)
            {
                try
                {
                    MethodInfo mi = session.GetType().GetMethod("ListModels");
                    if (mi != null)
                    {
                        object models = mi.Invoke(session, null);
                        if (models != null)
                        {
                            dynamic list = models;
                            int count = (int)list.Count;
                            string asmName = GetModelName(asmModel);
                            for (int i = 0; i < count; i++)
                            {
                                IpfcModel m = list[i] as IpfcModel;
                                if (m == null) continue;
                                if (m.Type != MDL_PART) continue;
                                string key = GetModelName(m);
                                if (string.Equals(key, asmName, StringComparison.OrdinalIgnoreCase)) continue;
                                if (seen.Add(key))
                                    result.Add(m);
                            }
                        }
                    }
                }
                catch { }
            }

            return result;
        }

