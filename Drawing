    public static class DrawingAutomation
    {
        private static readonly int MDL_PART = (int)EpfcModelType.EpfcMDL_PART;
        private static readonly int MDL_ASSEMBLY = (int)EpfcModelType.EpfcMDL_ASSEMBLY;
        private static readonly int MDL_DRAWING = (int)EpfcModelType.EpfcMDL_DRAWING;

        public static void RunFullDrawingWorkflow(
            IpfcBaseSession session,
            string stackXmlPath,
            IEnumerable<int> noteIds,
            string customText,
            string symbolPath,
            string symbolName,
            string symbolGroup,
            bool createViews,
            bool insertSymbol,
            bool createDataTables,
            bool showDimensionsInTable,
            bool processEachAssemblyComponent,
            bool explodeAssemblyBeforeDrawing,
            string sheetTemplate,
            string sheetSize)
        {
            if (session == null)
                throw new ArgumentNullException("session");

            List<int> ids = noteIds == null
                ? new List<int> { 840, 5, 23, 22, 25, 30 }
                : noteIds.Distinct().ToList();

            IpfcModel start = session.CurrentModel;
            if (start == null)
                throw new InvalidOperationException("No active model. Open a part or assembly first.");

            int startType = start.Type;
            Console.WriteLine("Start model: " + GetModelName(start) + " type=" + startType);

            // Already a drawing -> process that only
            if (startType == MDL_DRAWING)
            {
                IpfcModel solid;
                IpfcDrawing drw = EnsureDrawing(session, out solid, sheetTemplate, sheetSize, false);
                ProcessOneDrawing(
                    session, drw, solid, stackXmlPath, ids, customText,
                    symbolPath, symbolName, symbolGroup,
                    createViews, insertSymbol, createDataTables, showDimensionsInTable);
                return;
            }

            if (startType != MDL_PART && startType != MDL_ASSEMBLY)
                throw new InvalidOperationException("Active model must be part, assembly, or drawing.");

            // ===================== ASSEMBLY LOGIC =====================
            // Example: assembly has PLATE + BOLT
            // Creates 3 drawings:
            //   1) assembly overall drawing
            //   2) PLATE drawing
            //   3) BOLT drawing
            if (startType == MDL_ASSEMBLY)
            {
                Console.WriteLine("Assembly detected. Creating overall + per-part drawings...");

                if (explodeAssemblyBeforeDrawing)
                    TryExplodeAssembly(session, start);

                // 1) Overall assembly drawing
                Console.WriteLine("=== [1] ASSEMBLY drawing: " + GetModelName(start) + " ===");
                IpfcDrawing asmDrw = EnsureDrawingForSolid(session, start, sheetTemplate, sheetSize);
                ProcessOneDrawing(
                    session, asmDrw, start, stackXmlPath, ids, customText,
                    symbolPath, symbolName, symbolGroup,
                    createViews, insertSymbol, createDataTables, showDimensionsInTable);

                // 2) One drawing for each unique part component
                if (processEachAssemblyComponent)
                {
                    List<IpfcModel> parts = ListAssemblyPartModels(session, start);
                    Console.WriteLine("Unique part components: " + parts.Count);

                    int index = 0;
                    foreach (IpfcModel part in parts)
                    {
                        if (part == null) continue;
                        index++;
                        string pname = GetModelName(part);
                        Console.WriteLine("=== [" + (index + 1) + "] PART drawing: " + pname + " ===");

                        try
                        {
                            try { part.Display(); } catch { }
                            ActivateModelWindow(session, part);
                            Thread.Sleep(350);

                            IpfcDrawing partDrw = EnsureDrawingForSolid(session, part, sheetTemplate, sheetSize);
                            ProcessOneDrawing(
                                session, partDrw, part, stackXmlPath, ids, customText,
                                symbolPath, symbolName, symbolGroup,
                                createViews, insertSymbol, createDataTables, showDimensionsInTable);
                        }
                        catch (Exception ex)
                        {
                            Console.WriteLine("Part drawing failed for " + pname + ": " + ex.Message);
                        }
                    }
                }

                Console.WriteLine("Assembly multi-drawing workflow finished.");
                return;
            }

            // ===================== PART LOGIC =====================
            Console.WriteLine("Part detected.");
            IpfcDrawing partDrawing = EnsureDrawingForSolid(session, start, sheetTemplate, sheetSize);
            ProcessOneDrawing(
                session, partDrawing, start, stackXmlPath, ids, customText,
                symbolPath, symbolName, symbolGroup,
                createViews, insertSymbol, createDataTables, showDimensionsInTable);
        }

        private static void ProcessOneDrawing(
            IpfcBaseSession session,
            IpfcDrawing drawing,
            IpfcModel solid,
            string stackXmlPath,
            List<int> ids,
            string customText,
            string symbolPath,
            string symbolName,
            string symbolGroup,
            bool createViews,
            bool insertSymbol,
            bool createDataTables,
            bool showDimensionsInTable)
        {
            if (drawing == null)
                throw new InvalidOperationException("Drawing is null.");

            ActivateModelWindow(session, (IpfcModel)drawing);
            Console.WriteLine("Processing drawing: " + GetModelName((IpfcModel)drawing));

            if (solid != null)
                LinkModel(drawing, solid);

            if (createViews && solid != null)
            {
                Console.WriteLine("Creating aligned views (FRONT/RIGHT/TOP/ISO)...");
                try
                {
                    IpfcView2D front = EnsureGeneralView(drawing, solid, "FRONT", Layout.FrontX, Layout.FrontY);
                    if (front != null)
                    {
                        TryProjection(drawing, front, "RIGHT", Layout.RightDX, 0);
                        TryProjection(drawing, front, "TOP", 0, Layout.TopDY);
                    }
                    EnsureGeneralView(drawing, solid, "ISO", Layout.IsoX, Layout.IsoY);
                }
                catch (Exception ex)
                {
                    Console.WriteLine("View creation warning: " + ex.Message);
                }
                RefreshWindow(session);
            }

            if (createDataTables)
            {
                Console.WriteLine("Creating data tables (notes)...");
                try
                {
                    List<string> modelLines = BuildModelDataLines(drawing, solid, customText, ids);
                    CreateMultiLineNote(drawing, modelLines, Layout.ModelTableX, Layout.ModelTableY);

                    if (showDimensionsInTable)
                    {
                        List<string> dimLines = BuildDimensionDataLines(drawing, solid);
                        CreateMultiLineNote(drawing, dimLines, Layout.DimTableX, Layout.DimTableY);
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine("Data table warning: " + ex.Message);
                }
                RefreshWindow(session);
            }

            if (insertSymbol && !string.IsNullOrWhiteSpace(symbolPath) && !string.IsNullOrWhiteSpace(symbolName))
            {
                try
                {
                    InsertSymbol(session, drawing, symbolName, symbolPath, symbolGroup,
                        Layout.SymbolX, Layout.SymbolY);
                }
                catch (Exception ex)
                {
                    Console.WriteLine("Symbol skipped: " + ex.Message);
                }
                RefreshWindow(session);
            }

            // Stack notes
            try
            {
                string xmlForThis = stackXmlPath;
                try
                {
                    string baseDir = Path.GetDirectoryName(stackXmlPath) ?? ".";
                    string leaf = GetModelName((IpfcModel)drawing);
                    if (string.IsNullOrWhiteSpace(leaf)) leaf = "Stack_Notes";
                    xmlForThis = Path.Combine(baseDir, SanitizeFileName(leaf) + "_stack.xml");
                }
                catch { }

                StackNotes.GenerateUserSettingsXml(xmlForThis, ids, new[] { customText });
                StackNotes.ApplyStackNotesUi(session, ids, customText);
                StackNotes.PlaceStackNotes(session);
                StackNotes.CloseStrayDialogs(session);
                Thread.Sleep(200);
                StackNotes.CloseStrayDialogs(session);
            }
            catch (Exception ex)
            {
                Console.WriteLine("Stack notes warning: " + ex.Message);
                try { StackNotes.CloseStrayDialogs(session); } catch { }
            }

            RefreshWindow(session);
            Console.WriteLine("Finished drawing: " + GetModelName((IpfcModel)drawing));
        }

        private static string SanitizeFileName(string name)
        {
            if (string.IsNullOrEmpty(name)) return "model";
            foreach (char c in Path.GetInvalidFileNameChars())
                name = name.Replace(c, '_');
            return name;
        }

