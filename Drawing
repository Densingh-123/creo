    internal class Program
    {
        public static CCpfcAsyncConnection Asc;
        public static IpfcAsyncConnection Iac;
        public static IpfcBaseSession Session;

        private static readonly int[] NoteIds = { 840, 5, 23, 22, 25, 30 };
        private const string CustomNoteText = "SPOT WELDED (THIS IS CUSTOMIZED)";

        private const string SymbolLibraryPath = @"P:\proe\lib\symbols";
        private const string SymbolName = "SC_FLAGS_NOTES";
        private const string SymbolGroupName = "IMPORTANT";

        private const bool CreateViewsIfMissing = true;
        private const bool InsertSymbolFlag = true;
        private const bool CreateDataTables = true;
        private const bool ShowDimensionsInTable = true;
        static void Main(string[] args)
        {
            Connect();

            if (Session == null)
            {
                Console.WriteLine("No Creo session.");
                WaitExit();
                return;
            }

            try
            {
                string xmlPath = Path.Combine(
                    AppDomain.CurrentDomain.BaseDirectory,
                    "Stack_Notes.xml");

                DrawingAutomation.RunFullDrawingWorkflow(
                    Session,
                    xmlPath,
                    NoteIds,
                    CustomNoteText,
                    SymbolLibraryPath,
                    SymbolName,
                    SymbolGroupName,
                    CreateViewsIfMissing,
                    InsertSymbolFlag,
                    CreateDataTables,
                    ShowDimensionsInTable);

                Console.WriteLine("ALL DONE.");
                Console.WriteLine("If stack placement waits for a point, click once in the drawing.");
            }
            catch (Exception ex)
            {
                Console.WriteLine("ERROR: " + ex.Message);
                Console.WriteLine(ex);
            }

            WaitExit();
        }

        private static void WaitExit()
        {
            Console.WriteLine("Press any key to close...");
            Console.ReadKey();
        }

        public static void Connect()
        {
            try
            {
                Asc = new CCpfcAsyncConnection();
                Iac = Asc.Connect(null, null, null, null);
                Session = (IpfcBaseSession)Iac.Session;
                Console.WriteLine("Connected to Creo.");
            }
            catch
            {
                KillProcess("pfclscom");
                Connect2();
            }
        }

        private static void Connect2()
        {
            try
            {
                Asc = new CCpfcAsyncConnection();
                Iac = Asc.Connect(null, null, null, null);
                Session = (IpfcBaseSession)Iac.Session;
                Console.WriteLine("Connected to Creo (retry).");
            }
            catch (Exception ex)
            {
                Console.WriteLine("Creo connection failed: " + ex.Message);
            }
        }

        private static void KillProcess(string processName)
        {
            try
            {
                foreach (Process p in Process.GetProcessesByName(processName))
                    p.Kill();
            }
            catch { }
        }
    }


