        public static IpfcDrawing EnsureDrawingForSolid(
            IpfcBaseSession session,
            IpfcModel solid,
            string sheetTemplate,
            string sheetSize)
        {
            if (solid == null)
                throw new ArgumentNullException("solid");

            try { solid.Display(); } catch { }
            ActivateModelWindow(session, solid);
            Thread.Sleep(250);

            IpfcModel dummy;
            return EnsureDrawing(session, out dummy, sheetTemplate, sheetSize, true);
        }

        public static IpfcDrawing EnsureDrawing(
            IpfcBaseSession session,
            out IpfcModel solidModel,
            string sheetTemplate,
            string sheetSize,
            bool createIfMissing)
        {
            solidModel = null;
            IpfcModel current = session.CurrentModel;
            if (current == null)
                throw new InvalidOperationException("No active model.");

            int type = current.Type;
            Console.WriteLine("Active: " + GetModelName(current) + " type=" + type);

            if (type == MDL_DRAWING)
            {
                try
                {
                    IpfcModel2D m2d = (IpfcModel2D)current;
                    IpfcModels models = m2d.ListModels();
                    if (models != null && models.Count > 0)
                        solidModel = models[0];
                }
                catch { }

                ActivateModelWindow(session, current);
                return (IpfcDrawing)current;
            }

            if (type != MDL_PART && type != MDL_ASSEMBLY)
                throw new InvalidOperationException("Active model must be part, assembly, or drawing.");

            solidModel = current;
            string name = current.FullName;
            string path = NormalizePath(TryGetPath(current));

            Console.WriteLine("Looking for drawing: " + name + ".drw");
            if (!string.IsNullOrEmpty(path))
                Console.WriteLine("Solid path: " + path);

            IpfcModel drwModel = TryFindDrawing(session, name, path);

            if (drwModel == null && createIfMissing)
            {
                Console.WriteLine("Drawing not found. Creating new drawing for: " + name);
                drwModel = CreateNewDrawing(session, solidModel, name, sheetTemplate, sheetSize);
            }

            if (drwModel == null)
                throw new InvalidOperationException(
                    "Could not open or create drawing for '" + name + "'.");

            try { drwModel.Display(); } catch { }
            ActivateModelWindow(session, drwModel);
            Thread.Sleep(400);

            IpfcModel now = session.CurrentModel;
            if (now == null || now.Type != MDL_DRAWING)
            {
                drwModel = TryFindDrawing(session, name, path);
                if (drwModel != null)
                {
                    try { drwModel.Display(); } catch { }
                    ActivateModelWindow(session, drwModel);
                    now = session.CurrentModel;
                }
            }

            if (now == null || now.Type != MDL_DRAWING)
                throw new InvalidOperationException("Drawing exists/created but could not activate.");

            return (IpfcDrawing)now;
        }

        private static string NormalizePath(string path)
        {
            if (string.IsNullOrWhiteSpace(path)) return path;
            path = path.Trim();

            // Creo sometimes returns "\Users\..." without drive
            if (path.StartsWith("\\Users\\", StringComparison.OrdinalIgnoreCase) ||
                path.StartsWith("/Users/", StringComparison.OrdinalIgnoreCase))
            {
                string root = Path.GetPathRoot(Environment.GetFolderPath(Environment.SpecialFolder.UserProfile));
                if (!string.IsNullOrEmpty(root))
                {
                    string rest = path.TrimStart('\\', '/');
                    path = Path.Combine(root, rest);
                }
            }
            return path;
        }

        private static IpfcModel TryFindDrawing(IpfcBaseSession session, string name, string path)
        {
            IpfcModel drwModel = null;

            try { drwModel = session.GetModel(name, MDL_DRAWING); }
            catch { drwModel = null; }

            if (drwModel == null)
            {
                try { drwModel = RetrieveDrawing(session, name, path); }
                catch (Exception ex)
                {
                    Console.WriteLine("Retrieve drawing failed: " + ex.Message);
                }
            }

            if (drwModel == null && !string.IsNullOrEmpty(path))
            {
                try
                {
                    string file = Path.Combine(path.TrimEnd('\\', '/'), name + ".drw");
                    if (File.Exists(file))
                        drwModel = session.GetModelFromFileName(file);
                }
                catch (Exception ex)
                {
                    Console.WriteLine("GetModelFromFileName failed: " + ex.Message);
                }
            }

            return drwModel;
        }

        private static IpfcModel CreateNewDrawing(
            IpfcBaseSession session,
            IpfcModel solid,
            string drawingName,
            string sheetTemplate,
            string sheetSize)
        {
            try { solid.Display(); } catch { }
            ActivateModelWindow(session, solid);
            Thread.Sleep(300);

            IpfcModel created = TryCreateDrawingByApi(session, solid, drawingName);
            if (created != null)
                return created;

            Console.WriteLine("Creating drawing via macro...");
            string safeName = (drawingName ?? "DRW").Replace("`", "'");
            string tmpl = string.IsNullOrWhiteSpace(sheetTemplate) ? "Empty" : sheetTemplate;
            string size = string.IsNullOrWhiteSpace(sheetSize) ? "A3" : sheetSize;

            StringBuilder macro = new StringBuilder();
            macro.Append("<ESC><ESC>");
            macro.Append("~ Command `ProCmdModelNew`;");
            macro.Append("~ Select `new` `Type` 1 `Drawing`;");
            macro.Append("~ Update `new` `InputPanel` `" + safeName + "`;");
            macro.Append("~ Update `new` `InputPanel_default_template` 0;");
            macro.Append("~ Activate `new` `OK`;");

            if (string.Equals(tmpl, "Empty", StringComparison.OrdinalIgnoreCase))
            {
                macro.Append("~ Select `dwg_create` `Specify` 1 `Empty`;");
                macro.Append("~ Select `dwg_create` `rad_empty` 1;");
            }
            else
            {
                macro.Append("~ Select `dwg_create` `Specify` 1 `Template`;");
                macro.Append("~ Select `dwg_create` `TemplateList` 1 `" + tmpl + "`;");
            }

            macro.Append("~ Select `dwg_create` `Size` 1 `" + size + "`;");
            macro.Append("~ Activate `dwg_create` `psh_ok`;");

            session.RunMacro(macro.ToString());
            Thread.Sleep(2000);

            for (int i = 0; i < 20; i++)
            {
                try
                {
                    IpfcModel m = session.CurrentModel;
                    if (m != null && m.Type == MDL_DRAWING)
                    {
                        Console.WriteLine("Created/activated drawing: " + GetModelName(m));
                        try { LinkModel((IpfcDrawing)m, solid); } catch { }
                        return m;
                    }
                }
                catch { }
                Thread.Sleep(250);
            }

            IpfcModel found = TryFindDrawing(session, safeName, NormalizePath(TryGetPath(solid)));
            if (found != null)
            {
                try { found.Display(); } catch { }
                ActivateModelWindow(session, found);
                try { LinkModel((IpfcDrawing)found, solid); } catch { }
                return found;
            }

            try
            {
                string alt =
                    "~ Command `ProCmdModelNew`;" +
                    "~ Select `new` `Type` 1 `Drawing`;" +
                    "~ Activate `new` `OK`;" +
                    "~ Activate `dwg_create` `psh_ok`;";
                session.RunMacro(alt);
                Thread.Sleep(2000);
                IpfcModel m = session.CurrentModel;
                if (m != null && m.Type == MDL_DRAWING)
                {
                    try { LinkModel((IpfcDrawing)m, solid); } catch { }
                    return m;
                }
            }
            catch { }

            return null;
        }

        private static IpfcModel TryCreateDrawingByApi(IpfcBaseSession session, IpfcModel solid, string drawingName)
        {
            try
            {
                MethodInfo[] methods = session.GetType().GetMethods(BindingFlags.Public | BindingFlags.Instance);
                foreach (MethodInfo mi in methods)
                {
                    if (mi.Name.IndexOf("CreateDrawing", StringComparison.OrdinalIgnoreCase) < 0)
                        continue;

                    ParameterInfo[] ps = mi.GetParameters();
                    object result = null;
                    try
                    {
                        if (ps.Length == 2)
                            result = mi.Invoke(session, new object[] { drawingName, solid });
                        else if (ps.Length == 3)
                            result = mi.Invoke(session, new object[] { drawingName, solid, null });
                        else if (ps.Length == 1)
                            result = mi.Invoke(session, new object[] { drawingName });
                    }
                    catch { result = null; }

                    IpfcModel model = result as IpfcModel;
                    if (model != null)
                    {
                        Console.WriteLine("Drawing created by API: " + mi.Name);
                        return model;
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("API create drawing skipped: " + ex.Message);
            }
            return null;
        }

        private static IpfcModel RetrieveDrawing(IpfcBaseSession session, string drawingName, string path)
        {
            CCpfcModelDescriptor factory = new CCpfcModelDescriptor();
            IpfcModelDescriptor descr = factory.Create(MDL_DRAWING, drawingName, null);
            if (!string.IsNullOrEmpty(path))
            {
                string p = path.Trim();
                if (!p.EndsWith("\\") && !p.EndsWith("/")) p += "\\";
                descr.Path = p;
            }
            return session.RetrieveModel(descr);
        }

        private static string TryGetPath(IpfcModel model)
        {
            try
            {
                if (model != null && model.Descr != null)
                    return model.Descr.Path;
            }
            catch { }
            return null;
        }

