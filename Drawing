        public static List<string> BuildModelDataLines(
            IpfcDrawing drawing,
            IpfcModel solid,
            string customText,
            IList<int> noteIds)
        {
            string drawingName = GetModelName((IpfcModel)drawing);
            string modelName = solid != null ? GetModelName(solid) : "-";
            string modelType = "-";
            string mass = "-";
            string volume = "-";
            string density = "-";
            string surface = "-";
            string width = "-";
            string height = "-";
            string depth = "-";

            if (solid != null)
            {
                try
                {
                    int t = solid.Type;
                    if (t == MDL_PART) modelType = "PART";
                    else if (t == MDL_ASSEMBLY) modelType = "ASSEMBLY";
                    else modelType = t.ToString();
                }
                catch { }

                try
                {
                    IpfcSolid s = solid as IpfcSolid;
                    if (s != null)
                    {
                        IpfcMassProperty mp = s.GetMassProperty(null);
                        if (mp != null)
                        {
                            try { mass = FormatNum(mp.Mass); } catch { }
                            try { volume = FormatNum(mp.Volume); } catch { }
                            try { density = FormatNum(mp.Density, 6); } catch { }
                            try { surface = FormatNum(mp.SurfaceArea); } catch { }
                        }
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine("Mass property warning: " + ex.Message);
                }

                try
                {
                    double[] box = GetOutlineSize(solid);
                    if (box != null && box.Length >= 3)
                    {
                        width = FormatNum(Math.Abs(box[0]));
                        height = FormatNum(Math.Abs(box[1]));
                        depth = FormatNum(Math.Abs(box[2]));
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine("Outline warning: " + ex.Message);
                }
            }

            string custom = string.IsNullOrWhiteSpace(customText) ? "-" : customText.Trim();
            string idsText = (noteIds == null || noteIds.Count == 0) ? "-" : string.Join(", ", noteIds);

            List<string> lines = new List<string>();
            lines.Add("==== MODEL / DRAWING DATA ====");
            lines.Add(PadRow("Drawing", drawingName));
            lines.Add(PadRow("Model", modelName));
            lines.Add(PadRow("Type", modelType));
            lines.Add(PadRow("Mass", mass));
            lines.Add(PadRow("Volume", volume));
            lines.Add(PadRow("Density", density));
            lines.Add(PadRow("Surface Area", surface));
            lines.Add(PadRow("Width (X)", width));
            lines.Add(PadRow("Height (Y)", height));
            lines.Add(PadRow("Depth (Z)", depth));
            lines.Add(PadRow("Stack Note IDs", idsText));
            lines.Add(PadRow("Custom Note", custom));
            lines.Add(PadRow("Generated", DateTime.Now.ToString("yyyy-MM-dd HH:mm")));
            lines.Add("==============================");
            return lines;
        }

        public static List<string> BuildDimensionDataLines(IpfcDrawing drawing, IpfcModel solid)
        {
            List<string> lines = new List<string>();
            lines.Add("==== DIMENSION DATA ====");

            List<string> dims = new List<string>();
            try { CollectDimensionsFromModel((IpfcModel)drawing, dims, "DRW"); } catch { }
            if (solid != null)
            {
                try { CollectDimensionsFromModel(solid, dims, "MDL"); } catch { }
            }

            if (dims.Count == 0)
            {
                lines.Add("No dimensions found.");
            }
            else
            {
                List<string> unique = new List<string>();
                HashSet<string> seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                foreach (string d in dims)
                    if (seen.Add(d)) unique.Add(d);

                int count = Math.Min(unique.Count, Layout.MaxDimensionRows);
                lines.Add(PadRow("Count", unique.Count.ToString()));
                for (int i = 0; i < count; i++)
                    lines.Add(unique[i]);
            }

            lines.Add("========================");
            return lines;
        }

        private static void CollectDimensionsFromModel(IpfcModel model, List<string> output, string sourceTag)
        {
            if (model == null) return;
            IpfcModelItemOwner owner = model as IpfcModelItemOwner;
            if (owner == null) return;

            IpfcModelItems items = null;
            try { items = owner.ListItems(EpfcModelItemType.EpfcITEM_DIMENSION); }
            catch
            {
                try { items = owner.ListItems((EpfcModelItemType)((int)EpfcModelItemType.EpfcITEM_DIMENSION)); }
                catch { items = null; }
            }
            if (items == null) return;

            for (int i = 0; i < items.Count; i++)
            {
                try
                {
                    IpfcModelItem item = items[i];
                    if (item == null) continue;
                    string name = GetItemName(item, i);
                    string valueText = TryReadDimensionValue(item);
                    output.Add(PadRow(sourceTag + ":" + name, valueText));
                }
                catch { }
            }
        }

        private static string GetItemName(IpfcModelItem item, int index)
        {
            try
            {
                object n = item.GetName();
                if (n != null && !string.IsNullOrWhiteSpace(n.ToString()))
                    return n.ToString();
            }
            catch { }
            try { return "ID_" + item.Id; }
            catch { return "DIM_" + index; }
        }

        private static string TryReadDimensionValue(IpfcModelItem item)
        {
            if (item == null) return "-";
            string v = TryGetNumericMember(item, "DimValue", "Value", "NominalValue", "GetValue", "get_DimValue", "get_Value");
            if (v != null) return v;
            try
            {
                IpfcDimension dim = item as IpfcDimension;
                if (dim != null)
                {
                    v = TryGetNumericMember(dim, "DimValue", "Value", "NominalValue", "GetValue", "get_DimValue", "get_Value");
                    if (v != null) return v;
                }
            }
            catch { }
            try { return "ID=" + item.Id; } catch { return "-"; }
        }

        private static string TryGetNumericMember(object target, params string[] names)
        {
            if (target == null) return null;
            Type t = target.GetType();
            foreach (string name in names)
            {
                try
                {
                    PropertyInfo pi = t.GetProperty(name, BindingFlags.Public | BindingFlags.Instance);
                    if (pi != null)
                    {
                        string s = FormatObjectNumber(pi.GetValue(target, null));
                        if (s != null) return s;
                    }
                }
                catch { }

                try
                {
                    MethodInfo mi = t.GetMethod(name, BindingFlags.Public | BindingFlags.Instance, null, Type.EmptyTypes, null);
                    if (mi != null)
                    {
                        string s = FormatObjectNumber(mi.Invoke(target, null));
                        if (s != null) return s;
                    }
                }
                catch { }
            }
            return null;
        }

        private static string FormatObjectNumber(object val)
        {
            if (val == null) return null;
            try
            {
                if (val is double) return FormatNum((double)val);
                if (val is float) return FormatNum((float)val);
                if (val is decimal) return FormatNum((double)(decimal)val);
                if (val is int) return ((int)val).ToString();
                if (val is long) return ((long)val).ToString();
                double d;
                if (double.TryParse(val.ToString(), out d)) return FormatNum(d);
                string s = val.ToString();
                if (!string.IsNullOrWhiteSpace(s)) return s;
            }
            catch { }
            return null;
        }

        private static double[] GetOutlineSize(IpfcModel solidModel)
        {
            try
            {
                IpfcSolid solid = solidModel as IpfcSolid;
                if (solid == null) return null;

                try
                {
                    MethodInfo mi = solid.GetType().GetMethod("GetOutline", Type.EmptyTypes);
                    if (mi != null)
                    {
                        double[] box = PointsToExtents(mi.Invoke(solid, null));
                        if (box != null) return box;
                    }
                }
                catch { }

                try
                {
                    MethodInfo mi = solid.GetType().GetMethod("GetGeomOutline");
                    if (mi != null)
                    {
                        object pts = null;
                        ParameterInfo[] ps = mi.GetParameters();
                        if (ps.Length == 0) pts = mi.Invoke(solid, null);
                        else if (ps.Length == 2) pts = mi.Invoke(solid, new object[] { null, null });
                        double[] box = PointsToExtents(pts);
                        if (box != null) return box;
                    }
                }
                catch { }
            }
            catch { }
            return null;
        }

        private static double[] PointsToExtents(object pts)
        {
            if (pts == null) return null;
            try
            {
                dynamic d = pts;
                dynamic p0 = d[0];
                dynamic p1 = d[1];
                return new double[]
                {
                    Math.Abs((double)p1[0] - (double)p0[0]),
                    Math.Abs((double)p1[1] - (double)p0[1]),
                    Math.Abs((double)p1[2] - (double)p0[2])
                };
            }
            catch { return null; }
        }

        private static string PadRow(string key, string value)
        {
            if (key == null) key = "";
            if (value == null) value = "-";
            if (value.Length > 42) value = value.Substring(0, 39) + "...";
            return key.PadRight(14) + ": " + value;
        }

        private static string FormatNum(double v, int decimals = 4)
        {
            return v.ToString("F" + decimals);
        }

        public static void CreateMultiLineNote(IpfcDrawing drawing, List<string> lines, double x, double y)
        {
            if (drawing == null) throw new ArgumentNullException("drawing");
            if (lines == null || lines.Count == 0) return;

            CpfcDetailTextLines textLines = new CpfcDetailTextLines();
            for (int i = 0; i < lines.Count; i++)
            {
                string line = (lines[i] ?? "").Replace("`", "'");
                IpfcDetailText dtext = new CCpfcDetailText().Create(line);
                CpfcDetailTexts texts = new CpfcDetailTexts();
                texts.Append(dtext);
                IpfcDetailTextLine textLine = new CCpfcDetailTextLine().Create(texts);
                textLines.Append(textLine);
            }

            IpfcDetailNoteInstructions noteIns =
                new CCpfcDetailNoteInstructions().Create(textLines);

            CpfcPoint3D sheetPos = ToSheetPoint(drawing, MakePoint(x, y, 0));
            IpfcFreeAttachment attachment = new CCpfcFreeAttachment().Create(sheetPos);
            IpfcDetailLeaders leaders = new CCpfcDetailLeaders().Create();
            leaders.set_ItemAttachment(attachment);
            noteIns.set_Leader(leaders);
            try { noteIns.IsDisplayed = true; } catch { }

            IpfcDetailItemOwner owner = (IpfcDetailItemOwner)drawing;
            IpfcDetailItem item = owner.CreateDetailItem((IpfcDetailCreateInstructions)noteIns);
            try
            {
                IpfcDetailNoteItem noteItem = item as IpfcDetailNoteItem;
                if (noteItem != null) noteItem.Show();
            }
            catch { }

            Console.WriteLine("Note @ (" + x + "," + y + ") lines=" + lines.Count);
        }

