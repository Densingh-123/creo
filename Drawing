                IpfcView2D v = drw2d.CreateView((IpfcView2DCreateInstructions)proj);
                try { if (v != null) v.Name = name; } catch { }
                Console.WriteLine("Created projection " + name + " @ (" + x + "," + y + ")");
            }
            catch (Exception ex)
            {
                Console.WriteLine("Projection " + name + " failed: " + ex.Message);
            }
        }

        private static CpfcPoint3D MakePoint(double x, double y, double z)
        {
            CpfcPoint3D p = new CpfcPoint3D();
            p.Set(0, x);
            p.Set(1, y);
            p.Set(2, z);
            return p;
        }

        private static CpfcPoint3D ToSheetPoint(IpfcDrawing drawing, CpfcPoint3D pointloc)
        {
            try
            {
                if (drawing == null || pointloc == null) return pointloc;

                IpfcSheetOwner owner = (IpfcSheetOwner)drawing;
                IpfcTransform3D tr = owner.GetSheetTransform(1);
                if (tr == null) return pointloc;
                tr.Invert();
                IpfcPoint3D screenloc = tr.TransformPoint(pointloc);
                if (screenloc == null) return pointloc;

                CpfcPoint3D result = new CpfcPoint3D();
                result.Set(0, screenloc[0]);
                result.Set(1, screenloc[1]);
                try { result.Set(2, screenloc[2]); } catch { result.Set(2, 0); }
                return result;
            }
            catch
            {
                try
                {
                    CpfcPoint3D copy = new CpfcPoint3D();
                    copy.Set(0, pointloc[0]);
                    copy.Set(1, pointloc[1]);
                    try { copy.Set(2, pointloc[2]); } catch { copy.Set(2, 0); }
                    return copy;
                }
                catch { return pointloc; }
            }
        }

        private static void NormalizeMatrix(IpfcMatrix3D matrix)
        {
            if (matrix == null) return;

            try
            {
                for (int i = 0; i < 3; i++)
                    matrix.Set(3, i, 0.0);

                for (int row = 0; row < 3; row++)
                {
                    double length = Math.Sqrt(
                        matrix[row, 0] * matrix[row, 0] +
                        matrix[row, 1] * matrix[row, 1] +
                        matrix[row, 2] * matrix[row, 2]);
                    if (length > 0.00001)
                    {
                        matrix.Set(row, 0, matrix[row, 0] / length);
                        matrix.Set(row, 1, matrix[row, 1] / length);
                        matrix.Set(row, 2, matrix[row, 2] / length);
                    }
                }
            }
            catch { }
        }

        private static void IdentityMatrix(IpfcMatrix3D matrix)
        {
            if (matrix == null) return;
            matrix.Set(0, 0, 1); matrix.Set(0, 1, 0); matrix.Set(0, 2, 0);
            matrix.Set(1, 0, 0); matrix.Set(1, 1, 1); matrix.Set(1, 2, 0);
            matrix.Set(2, 0, 0); matrix.Set(2, 1, 0); matrix.Set(2, 2, 1);
            matrix.Set(3, 0, 0); matrix.Set(3, 1, 0); matrix.Set(3, 2, 0);
        }

        private static void IsoMatrix(IpfcMatrix3D matrix)
        {
            if (matrix == null) return;
            matrix.Set(0, 0, 0.70710678); matrix.Set(0, 1, -0.70710678); matrix.Set(0, 2, 0.0);
            matrix.Set(1, 0, 0.40824829); matrix.Set(1, 1, 0.40824829); matrix.Set(1, 2, -0.81649658);
            matrix.Set(2, 0, 0.57735027); matrix.Set(2, 1, 0.57735027); matrix.Set(2, 2, 0.57735027);
            matrix.Set(3, 0, 0); matrix.Set(3, 1, 0); matrix.Set(3, 2, 0);
            NormalizeMatrix(matrix);
        }

        public static void InsertSymbol(
            IpfcBaseSession session,
            IpfcDrawing drawing,
            string symbolName,
            string symbolPath,
            string groupName,
            double x,
            double y)
        {
            if (drawing == null) throw new ArgumentNullException("drawing");
            if (string.IsNullOrWhiteSpace(symbolName)) return;

            string symbolFile = Path.Combine(symbolPath ?? string.Empty, symbolName + ".sym");
            if (!string.IsNullOrEmpty(symbolPath) && !Directory.Exists(symbolPath))
                throw new DirectoryNotFoundException("Symbol directory missing: " + symbolPath);
            if (!string.IsNullOrEmpty(symbolPath) && !File.Exists(symbolFile))
                throw new FileNotFoundException("Symbol file not found: " + symbolFile);

            IpfcDetailItemOwner owner = (IpfcDetailItemOwner)drawing;
            IpfcDetailSymbolDefItem symbolDef =
                owner.RetrieveSymbolDefinition(symbolName, symbolPath, null, null);

            CpfcPoint3D sheetPoint = ToSheetPoint(drawing, MakePoint(x, y, 0));
            IpfcFreeAttachment attachment = new CCpfcFreeAttachment().Create(sheetPoint);
            IpfcDetailLeaders leaders = new CCpfcDetailLeaders().Create();
            leaders.set_ItemAttachment(attachment);

            IpfcDetailSymbolInstInstructions inst =
                new CCpfcDetailSymbolInstInstructions().Create(symbolDef);
            inst.set_InstAttachment(leaders);

            if (!string.IsNullOrWhiteSpace(groupName))
            {
                try
                {
                    IpfcDetailSymbolGroups groups = (IpfcDetailSymbolGroups)symbolDef.ListSubgroups();
                    if (groups != null)
                    {
                        for (int i = 0; i < groups.Count; i++)
                        {
                            IpfcDetailSymbolGroup grp = groups[i];
                            if (grp == null) continue;
                            string gname = grp.GetInstructions().Name;
                            if (string.Equals(gname, groupName, StringComparison.OrdinalIgnoreCase))
                            {
                                IpfcDetailSymbolGroups selected = (IpfcDetailSymbolGroups)new CpfcDetailSymbolGroups();
                                selected.Append(grp);
                                inst.SetGroups(
                                    (int)EpfcDetailSymbolGroupOption.EpfcDETAIL_SYMBOL_GROUP_CUSTOM,
                                    selected);
                                break;
                            }
                        }
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine("Symbol group skipped: " + ex.Message);
                }
            }

            IpfcDetailSymbolInstItem item =
                (IpfcDetailSymbolInstItem)owner.CreateDetailItem((IpfcDetailCreateInstructions)inst);
            if (item != null) item.Show();
            RefreshWindow(session);
            Console.WriteLine("Symbol inserted: " + symbolName);
        }
    }

    public static class StackNotes
    {
        public static void GenerateUserSettingsXml(
            string fullXmlPath,
            IEnumerable<int> predefinedNoteIds,
            IEnumerable<string> customNoteLines,
            string language = "usascii")
        {
            var root = new XElement("user_settings");

            foreach (int id in predefinedNoteIds.Distinct())
            {
                root.Add(new XElement("note_def",
                    new XAttribute("is_custom_note", "false"),
                    new XElement("note_id", id)));
            }

            foreach (string line in customNoteLines.Where(s => !string.IsNullOrWhiteSpace(s)))
            {
                root.Add(new XElement("note_def",
                    new XAttribute("is_custom_note", "true"),
                    new XElement("language",
                        new XAttribute("name", language),
                        new XElement("line", line.Trim()))));
            }

            var doc = new XDocument(new XDeclaration("1.0", "utf-8", "yes"), root);
            string dir = Path.GetDirectoryName(fullXmlPath);
            if (!string.IsNullOrEmpty(dir))
                Directory.CreateDirectory(dir);
            doc.Save(fullXmlPath);
            Console.WriteLine("XML written: " + fullXmlPath);
        }

        public static void ApplyStackNotesUi(IpfcBaseSession session, IList<int> noteIds, string customText)
        {
            string openMacro =
                "~ Activate `main_dlg_cur` `user_custom_page_41955272_control_btn` 1;" +
                "~ Activate `main_dlg_cur` `user_custom_page_41955272:sn`;";

            Console.WriteLine("Opening Stack Notes...");
            session.RunMacro(openMacro);
            Thread.Sleep(900);

            var sb = new StringBuilder();
            foreach (int id in noteIds)
            {
                sb.Append("~ Activate `dlg_main` `cb_");
                sb.Append(id);
                sb.Append("tbl_stack_notes_dynamic` 1;");
            }
            Console.WriteLine("Selecting note IDs: " + string.Join(", ", noteIds));
            session.RunMacro(sb.ToString());
            Thread.Sleep(300);

            if (!string.IsNullOrWhiteSpace(customText))
            {
                string customMacro =
                    "~ Arm `dlg_main` `tbl_stack_notes_static` 2 `24` `value`;" +
                    "~ Disarm `dlg_main` `tbl_stack_notes_static` 2 `24` `value`;" +
                    "~ Select `dlg_main` `tbl_stack_notes_static` 0;" +
                    "~ Activate `UI Message Dialog` `yes`;" +
                    "~ Update `dlg_custom_note` `ta_text_1` `" + EscapeMacro(customText) + "`;" +
                    "~ Activate `dlg_custom_note` `pb_ok`;";
                session.RunMacro(customMacro);
                Thread.Sleep(300);
            }

            session.RunMacro("~ Activate `dlg_main` `pb_ok`;");
            Thread.Sleep(200);
            CloseStrayDialogs(session);
        }

        public static void PlaceStackNotes(IpfcBaseSession session)
        {
            Console.WriteLine("Placing stack notes...");
            session.RunMacro("~ Command `SAN_MAIN_STACK_NOTES`;");
            Thread.Sleep(250);
            CloseStrayDialogs(session);
        }

        public static void CloseStrayDialogs(IpfcBaseSession session)
        {
            string closeMacro =
                "~ Activate `file_open` `Cancel`;" +
                "~ Activate `file_open` `close_pb`;" +
                "~ Activate `file_saveas` `Cancel`;" +
                "~ Activate `dlg_custom_note` `pb_ok`;" +
                "~ Activate `dlg_custom_note` `pb_cancel`;" +
                "~ Activate `dlg_custom_note` `pb_close`;" +
                "~ Activate `dlg_main` `pb_ok`;" +
                "~ Activate `dlg_main` `pb_cancel`;" +
                "~ Activate `dlg_main` `pb_close`;" +
                "~ Activate `dlg_main` `Close`;" +
                "~ Command `ProCmdWinCloseChild`;" +
                "<ESC><ESC><ESC>;";
            try
            {
                session.RunMacro(closeMacro);
                Thread.Sleep(200);
            }
            catch { }
        }

        private static string EscapeMacro(string text)
        {
            if (text == null) return string.Empty;
            return text.Replace("`", "'");
        }
