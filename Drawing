                                string.Equals(views[i].Name, name, StringComparison.OrdinalIgnoreCase))
                            {
                                Console.WriteLine("Projection exists: " + name);
                                return;
                            }
                        }
                    }
                }
                catch { }

                double x = Layout.FrontX + dx;
                double y = Layout.FrontY + dy;
                CpfcPoint3D screenloc = ToSheetPoint(drawing, MakePoint(x, y, 0));

                IpfcProjectionViewCreateInstructions proj =
