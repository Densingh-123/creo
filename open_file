public static void OpenModelInCreo()
    {
        try
        {
                string filePath = "C:\\Users\\DensinghD\\Documents\\Creo_part\\box.prt.1";

            if (Session == null)
            {
                Console.WriteLine("Could not connect to an active Creo session.");
                return;
            }

         
            if (string.IsNullOrEmpty(filePath))
            {
                Console.WriteLine("File path string parameter cannot be empty.");
                return;
            }

            Console.WriteLine($"Processing file target: {filePath}");

            IpfcModelDescriptor desc = new CCpfcModelDescriptor().CreateFromFileName(filePath);

           
            IpfcWindow newWindow = Session.OpenFile(desc);

            if (newWindow != null)
            {
               
                newWindow.Activate();
                Console.WriteLine("File opened successfully and brought to active viewport focus!");
            }
            else
            {
                Console.WriteLine("File processed, but failed to generate a window frame context.");
            }
        }
        catch (System.Runtime.InteropServices.COMException comEx)
        {
            Console.WriteLine($"Creo Native Toolkit COM Error: {comEx.Message}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Application Error: {ex.Message}");
        }
    }

