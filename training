        private static void Kill_Process(
           string processName)
        {
            try
            {
                Process[] processes =
                    Process.GetProcessesByName(
                        processName);

                foreach (Process process in processes)
                {
                    process.Kill();
                }
            }
            catch
            {
            }
        }
        public static void SetCustomOrientation()
        {
 
            try
            {
                Console.WriteLine("Connecting to active Creo session...");


                IpfcModel model = Session.CurrentModel;

                if (model == null || model.Type != (int)EpfcModelType.EpfcMDL_PART)
                {
                    Console.WriteLine("ERROR: Please open a valid Creo Part model first.");
                    return;
                }
 
                IpfcMatrix3D matrix = new CpfcMatrix3D();

                matrix.Set(0, 0, 1.0); matrix.Set(0, 1, 0.0); matrix.Set(0, 2, 0.0); matrix.Set(0, 3, 0.0);
                matrix.Set(1, 0, 0.0); matrix.Set(1, 1, 1.0); matrix.Set(1, 2, 0.0); matrix.Set(1, 3, 0.0);
                matrix.Set(2, 0, 0.0); matrix.Set(2, 1, 0.0); matrix.Set(2, 2, 1.0); matrix.Set(2, 3, 0.0);
                matrix.Set(3, 3, 0.0); matrix.Set(3, 3, 0.0); matrix.Set(3, 2, 0.0); matrix.Set(3, 3, 1.0);

                IpfcTransform3D transform = new CCpfcTransform3D().Create(matrix);
                IpfcViewOwner viewOwner = (IpfcViewOwner)model;

                viewOwner.SetCurrentViewTransform(transform);
 
                string viewName = "MY_ORIENTATION";
                viewOwner.SaveView(viewName);

                IpfcWindow currentWindow = Session.get_CurrentWindow();
                if (currentWindow != null)
                {
                    currentWindow.Repaint();
                }

                Console.WriteLine("SUCCESS: Custom Orientation '" + viewName + "' has been successfully registered!");
            }
            catch (Exception ex)
            {
                Console.WriteLine("EXECUTION ERROR: " + ex.Message);
            }
            Console.WriteLine("Press any key to exit...");
            Console.ReadKey();
        }
        public static void Note(IpfcDrawing drawing, string text, int x_axis, int y_axis)
        {
            try
            {
             
                IpfcDetailItemOwner detowner = (IpfcDetailItemOwner)drawing;            
                IpfcDetailText detline = new CCpfcDetailText().Create(text);
                CpfcDetailTexts dtltexts = new CpfcDetailTexts();
                dtltexts.Append(detline);
                IpfcDetailTextLine singleLine = new CCpfcDetailTextLine().Create(dtltexts);
                CpfcDetailTextLines textlinesCollection = new CpfcDetailTextLines();
                textlinesCollection.Append(singleLine);
      
                CpfcPoint3D pointloc = new CpfcPoint3D();
                pointloc.Set(0, (594 * 0.5) + x_axis); 
                pointloc.Set(1, (420 * 0.5) + y_axis);
                pointloc.Set(2, 0.0);                
            
                IpfcFreeAttachment location = new CCpfcFreeAttachment().Create(pointloc);
        
                IpfcDetailNoteItem note = detowner.CreateFreeNote(textlinesCollection, location);
            
                note.Show();

                Session.get_CurrentWindow().Repaint();

                Console.WriteLine("SUCCESS: Text note was generated and displayed perfectly.");
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error generating note: " + ex.Message);
            }
        }
        public static void AddTable(IpfcDrawing drawing)
        {
            IpfcTableOwner owner = (IpfcTableOwner)drawing;
            int x = -270;
            int y = 110;
            IpfcPoint3D pointloc = new CpfcPoint3D();
            pointloc.Set(0, 594 * 0.5 + x);
            pointloc.Set(1, 420 * 0.5 + y);
            IpfcTableCreateInstructions tbins = new CCpfcTableCreateInstructions().Create((CpfcPoint3D)pointloc);
            Irealseq seq = new Crealseq();
            for(int i = 0; i < 5; i++)
            {
                seq.Set(i, 10); 
            }
            tbins.RowHeights = (Crealseq)seq;
            IpfcColumnCreateOption clmcropt = new CCpfcColumnCreateOption().Create((int)EpfcColumnJustification.EpfcCOL_JUSTIFY_LEFT,45.0);
            IpfcColumnCreateOptions clmcropts = new CpfcColumnCreateOptions();
            for(int i = 0; i < 2; i++)
            {
                clmcropts.Set(i, clmcropt);
            }
        } 
        public static void GetSymbolGroups()
        {
            IpfcModel model = Session.CurrentModel;
            if (model == null || model.Type != (int)EpfcModelType.EpfcMDL_DRAWING)
            {
                Console.WriteLine("Please open a drawing file first.");
                return;
            }

            IpfcDrawing draw = (IpfcDrawing)model;
            IpfcModelItemOwner owner = (IpfcModelItemOwner)draw;

            IpfcModelItems modelitems = owner.ListItems(EpfcModelItemType.EpfcITEM_DTL_SYM_INSTANCE);
            int count = modelitems.Count;

            for (int i = 0; i < count; i++)
            {
                IpfcDetailSymbolInstItem institem = (IpfcDetailSymbolInstItem)modelitems[i];

                IpfcDetailSymbolInstInstructions instInstructions = institem.GetInstructions(false);
                string symbolName = instInstructions.SymbolDef.GetInstructions().Name;

                string symbolPrefix = (i == count - 1) ? "    └── " : "    ├── ";
                Console.WriteLine($"{symbolPrefix}Symbol Instance: {symbolName} ");

                if (symbolName == "SC_FLAGS_NOTES")
                {
                    IpfcDetailSymbolGroups activeGroups = institem.ListGroups((int)EpfcSymbolGroupFilter.EpfcDTLSYMINST_ACTIVE_GROUPS);
                    int groupCount = activeGroups.Count;

                    string childIndent = (i == count - 1) ? "        " : "    │   ";

                    if (groupCount == 0)
                    {
                        Console.WriteLine($"{childIndent}└── [No Active Groups Selected]");
                    }
                    else
                    {
                        for (int j = 0; j < groupCount; j++)
                        {
                            IpfcDetailSymbolGroup groupItem = activeGroups[j];
                            string groupName = groupItem.GetInstructions().Name;

                            string groupPrefix = (j == groupCount - 1) ? "└── " : "├── ";
                            Console.WriteLine($"{childIndent}{groupPrefix}Active Group: {groupName}");
                        }
                    }
                }
            }
        }
