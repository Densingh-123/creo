        public void FindSymbol()
        {
            try
            {
                IpfcModel model = Session.GetActiveModel();

                if (model == null)
                {
                    MessageBox.Show("No active model.");
                    return;
                }

                if (model.Type != (int)EpfcModelType.EpfcMDL_DRAWING)
                {
                    MessageBox.Show("Current model is not a drawing.");
                    return;
                }


                IpfcDrawing drawing = (IpfcDrawing)model;


                IpfcDetailItemOwner owner =
                    (IpfcDetailItemOwner)drawing;


                IpfcDetailItems detailItems =
                    owner.ListDetailItems(null, null);


                if (detailItems == null || detailItems.Count == 0)
                {
                    MessageBox.Show("No detail items found.");
                    return;
                }


                StringBuilder result = new StringBuilder();

                int symbolCount = 0;


                for (int i = 0; i < detailItems.Count; i++)
                {
                    IpfcDetailItem item = detailItems[i];

                    if (item is IpfcDetailSymbolInstItem)
                    {
                        symbolCount++;

                        IpfcDetailSymbolInstItem symbol =
                            (IpfcDetailSymbolInstItem)item;


                        result.AppendLine(
                            "Symbol Number : " + symbolCount);


                        try
                        {
                            IpfcDetailSymbolInstInstructions instruction =
                                symbol.GetInstructions(false);


                            if (instruction != null)
                            {
                                result.AppendLine(
                                    "Symbol instruction found");
                            }
                        }
                        catch (Exception)
                        {
                            result.AppendLine(
                                "Unable to read symbol instruction");
                        }


                        result.AppendLine(
                            "----------------------------");
                    }
                }


                if (symbolCount == 0)
                {
                    MessageBox.Show(
                        "No symbols found in drawing.");
                }
                else
                {
                    MessageBox.Show(result.ToString());
                }

            }
            catch (COMException ex)
            {
                MessageBox.Show(
                    "Creo Toolkit Error:\n\n" +
                    ex.Message +
                    "\nHRESULT : " +
                    ex.ErrorCode);
            }
            catch (Exception ex)
            {
                MessageBox.Show(
                    "Error:\n" +
                    ex.Message);
            }
        }
        public void InsertSymbol(IpfcDrawing drawing, string symbolName)
        {
            try
            {
                if (drawing == null)
                {
                    MessageBox.Show("Drawing is NULL.");
                    return;
                }

                string symbolPath = @"P:\proe\lib\symbols";
                string symbolFile = Path.Combine(symbolPath, symbolName + ".sym");

                if (!Directory.Exists(symbolPath))
                {
                    MessageBox.Show("Symbol directory does not exist.\n" + symbolPath);
                    return;
                }

                if (!File.Exists(symbolFile))
                {
                    MessageBox.Show("Symbol file not found.\n" + symbolFile);
                    return;
                }

                IpfcDetailItemOwner owner = (IpfcDetailItemOwner)drawing;

                IpfcDetailSymbolDefItem symbolDef = null;

                //---------------------------------------------------------
                // Try to retrieve symbol
                //---------------------------------------------------------
                try
                {
                    symbolDef = owner.RetrieveSymbolDefinition(
                                    symbolName,
                                    symbolPath,
                                    null,
                                    null);

                    MessageBox.Show("Symbol Definition Loaded.");
                }
                catch (COMException ex)
                {
                    MessageBox.Show(
                        "RetrieveSymbolDefinition Failed\n\n" +
                        ex.Message +
                        "\nHRESULT : " + ex.ErrorCode);

                    return;
                }

                //---------------------------------------------------------
                // Location
                //---------------------------------------------------------

                CpfcPoint3D point = new CpfcPoint3D();

                point.Set(0, 420);
                point.Set(1, 280);

                IpfcFreeAttachment attachment =
                    new CCpfcFreeAttachment().Create(point);

                IpfcDetailLeaders leaders =
                    new CCpfcDetailLeaders().Create();

                leaders.set_ItemAttachment(attachment);

                //---------------------------------------------------------
                // Create instruction
                //---------------------------------------------------------

                IpfcDetailSymbolInstInstructions inst =
                    new CCpfcDetailSymbolInstInstructions().Create(symbolDef);

                inst.set_InstAttachment(leaders);

                //---------------------------------------------------------
                // Find IMPORTANT group
                //---------------------------------------------------------

                try
                {
                    IpfcDetailSymbolGroups groups =
                        (IpfcDetailSymbolGroups)symbolDef.ListSubgroups();

                    if (groups != null)
                    {
                        for (int i = 0; i < groups.Count; i++)
                        {
                            IpfcDetailSymbolGroup grp = groups[i];

                            string name =
                                grp.GetInstructions().Name;

                            Debug.WriteLine(name);

                            if (name.Equals("IMPORTANT",
                                StringComparison.OrdinalIgnoreCase))
                            {
                                IpfcDetailSymbolGroups selected =
                                    (IpfcDetailSymbolGroups)new CpfcDetailSymbolGroups();

                                selected.Append(grp);

                                inst.SetGroups(
                                    (int)EpfcDetailSymbolGroupOption.EpfcDETAIL_SYMBOL_GROUP_CUSTOM,
                                    selected);

                                break;
                            }
                        }
                    }
                }
                catch
                {
                }

               

                try
                {
                    IpfcDetailSymbolInstItem item =
                        (IpfcDetailSymbolInstItem)
                        owner.CreateDetailItem(
                            (IpfcDetailCreateInstructions)inst);

                    item.Show();

                    Session.get_CurrentWindow().Refresh();
                    Session.get_CurrentWindow().Repaint();

                    MessageBox.Show("Symbol Inserted Successfully.");
                }
                catch (COMException ex)
                {
                    MessageBox.Show(
                        "CreateDetailItem Failed\n\n" +
                        ex.Message +
                        "\nHRESULT : " + ex.ErrorCode);
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.ToString());
            }
        }
