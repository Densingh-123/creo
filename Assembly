        private static void KillProcess(
            string processName)
        {
            try
            {
                Process[] processes =
                    Process.GetProcessesByName(
                        processName);

                foreach (Process process in processes)
                {
                    process.Kill();
                }
            }
            catch
            {
            }
        }
