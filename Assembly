        public static void Normalizematrix(IpfcMatrix3D matrix)
        {
            matrix.Set(0, 0, 1);
            matrix.Set(0, 1, 0);
            matrix.Set(0, 2, 0);

            matrix.Set(1, 0, 0);
            matrix.Set(1, 1, 1);
            matrix.Set(1, 2, 0);

            matrix.Set(2, 0, 0);
            matrix.Set(2, 1, 0);
            matrix.Set(2, 2, 1);
        }
