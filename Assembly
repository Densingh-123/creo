        public IpfcView2D PartViews(string viewname,
                             IpfcDrawing mydrw,
                             IpfcModel model)
        {
            try
            {
                IpfcModel2D drw2d = (IpfcModel2D)mydrw;

                bool exists = false;

                IpfcModels models = drw2d.ListModels();

                for (int i = 0; i < models.Count; i++)
                {
                    if (models[i].InstanceName == model.InstanceName)
                    {
                        exists = true;
                        break;
                    }
                }

                if (!exists)
                    drw2d.AddModel(model);

                IpfcViewOwner owner = (IpfcViewOwner)model;

                IpfcView sourceView = owner.GetView(viewname);

                CpfcMatrix3D matrix =
                    (CpfcMatrix3D)sourceView.Transform.Matrix;

                Normalize_matrix(matrix);

                IpfcTransform3D transform =
                    new CCpfcTransform3D().Create(matrix);

                CpfcPoint3D pt = new CpfcPoint3D();

                pt.Set(0, 300);
                pt.Set(1, 200);

                IpfcSheetOwner sheetOwner =
                    (IpfcSheetOwner)mydrw;

                IpfcTransform3D sheetTransform =
                    sheetOwner.GetSheetTransform(1);

                sheetTransform.Invert();

                CpfcPoint3D sheetPt =
                    sheetTransform.TransformPoint(pt);

                IpfcGeneralViewCreateInstructions gvi =
                    new CCpfcGeneralViewCreateInstructions()
                    .Create(model,
                            1,
                            sheetPt,
                            transform);

                IpfcView2D newView =
                    drw2d.CreateView((IpfcView2DCreateInstructions)gvi);

                newView.Name = viewname;

                return newView;
            }
            catch (Exception ex)
            {
                MessageBox.Show("View Error : " + ex.Message);
                return null;
            }
        }

        public static void Normalize_matrix(IpfcMatrix3D matrix)
        {

            for (int i = 0; i < 3; i++)
            {
                matrix.Set(3, i, 0.0);
            }

            for (int row = 0; row < 3; row++)
            {
                double length = Math.Sqrt(matrix[row, 0] * matrix[row, 0] +
                                          matrix[row, 1] * matrix[row, 1] +
                                          matrix[row, 2] * matrix[row, 2]);
                if (length > 0.00001)
                {
                    matrix.Set(row, 0, matrix[row, 0] / length);
                    matrix.Set(row, 1, matrix[row, 1] / length);
                    matrix.Set(row, 2, matrix[row, 2] / length);
                }
            }
        }

        public IpfcModel LinkModel(IpfcDrawing mydrw, string modelname)
        {
            try
            {
                IpfcModel2D drw2D = (IpfcModel2D)mydrw;

                // Current model filename already contains extension
                IpfcModel model3D = Session.GetModelFromFileName(modelname);

                if (model3D == null)
                {
                    MessageBox.Show("Unable to load model : " + modelname);
                    return null;
                }

                bool exists = false;

                IpfcModels models = drw2D.ListModels();

                if (models != null)
                {
                    for (int i = 0; i < models.Count; i++)
                    {
                        if (models[i].InstanceName.Equals(model3D.InstanceName,
                            StringComparison.OrdinalIgnoreCase))
                        {
                            exists = true;
                            break;
                        }
                    }
                }

                if (!exists)
                    drw2D.AddModel(model3D);

                return model3D;
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
                return null;
            }
        }
